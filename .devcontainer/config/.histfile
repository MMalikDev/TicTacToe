bat "$(fzp -m)"
bat .env
bat package.json | jq '.scripts'
bun i
bun run format
cls
df -h
diffs .env .env.example
docker builder prune
docker compose -f compose.yaml down
docker compose -f compose.yaml up
docker compose down
docker compose up
docker compose up -d
docker compose version
docker images
docker ps
docker ps --format "{{.Names}}: {{.Ports}}"
docker ps --format "{{.Names}}: {{.Ports}}" | awk -F '[->:]' '{print $1 ": " $2}'"
docker ps -a
docker rmi
docker version
docker volume ls
dp
dps
echo "$0"
echo $PATH | tr ":" "\n"
fd -HIt d '\.venv'
fd -He json -x chmod 640
fd -He sh -x chmod +x
fd -Ht d -x chmod 751
fd -Ht f -x chmod 640
fd -Ht f shada
fd -e sh --exec chmod 750
fd -e sh --exec chmod 770
fd -t d
fd -t d -x chmod 751
fd -t d -x chmod 755
fd -t f -x chmod 640
fd json --exec chmod 640
fd json --exec chmod 644
fd json | fzf --preview-window wrap --preview='bat {} | jq -C'
fdisk -l
gac "$(printf "Enter commit message: ">&2; read i; echo "$i")"
gb -D "$(gb | fzf | cut -d ' ' -f2-)"
gc "$(printf "Enter commit message: ">&2; read i; echo "$i")"
git add $(git ls-files -m | fzf -m --preview-window wrap --preview="git diff --color {}")
git branch -D $(gb | fzf | cut -d ' ' -f2-)
git checkout $(gb | fzf | cut -d ' ' -f2-)
git checkout $(printf "Enter branch name: ">&2; read i; echo "$i")
git checkout -b $(printf "Enter new branch name: ">&2; read i; echo "$i")
git commit --amend --no-edit
git commit --amend -m  "$(printf "Enter commit message: ">&2; read i; echo "$i")"
git diff --name-only HEAD~1 | cut -d/ -f1 | sort -u
git diff --name-only HEAD~1 | fzf -m --preview-window wrap --preview="git diff --color=always HEAD~1 {}"
git diff HEAD~1
git gc
git init
git log --oneline -a --graph
git ls-files
git pull
git pull --rebase
git pull origin main
git push -d origin $(printf "Enter branch name: ">&2; read i; echo "$i")
git push origin $(gb | fzf | cut -d ' ' -f2-)
git push origin *
git rebase $(gb | fzf | cut -d ' ' -f2-)
git rebase $(printf "Enter branch name: ">&2; read i; echo "$i")
git rebase --abort
git rebase --continue
git rebase -i "$(printf "Enter HEAD~ # : ">&2; read i; echo "HEAD~$i")"
git reset $(git ls-files -m | fzf -m --preview-window wrap --preview="git diff --color --staged {}")
git reset --hard "$(printf "Enter HEAD~ # : ">&2; read i; echo "HEAD~$i")"
git reset --soft "$(printf "Enter HEAD~ # : ">&2; read i; echo "HEAD~$i")"
git reset .
git restore $(git ls-files -m | fzf -m --preview-window wrap --preview="git diff --color {}")
git restore .
git rev-parse --is-inside-work-tree
git stash
git stash list
git stash pop
git status push -m "$(printf "Enter stash message: ">&2; read i; echo "$i")"
gp $(gb | fzf | cut -d ' ' -f2-)
gu $(gb | fzf | cut -d ' ' -f2-)
helix
helix --health
helix .
lsi -lAs size --total-size
lsl -RL 1
lsl -RL 2
npm audit fix --force
npm i
npm run format
npm run format && npm run lint && npm run check
pacman -Qq | fzf --preview-window wrap -m --preview="pacman -Qi {}"
pacman -Qqe | fzf --preview-window wrap -m --preview="pacman -Qi {}"
rsync --delete-after -Phav
rsync --delete-after -Phav --exclude=".venv"
sudo pacman -Runs  $(pacman -Qq | fzf --preview-window wrap -m --preview="pacman -Qi {}")
sudo pacman -Syu
tail -f proxy/config/traefik/logs/access.log | fzf -m --preview-window wrap --preview='echo {} | jq -C .'
tail -f proxy/config/traefik/logs/traefik.log | fzf -m --preview-window wrap --preview='echo {} | jq -C .'
tail -f proxy/config/traefik/logs/traefik.log | fzf -m --preview-window wrap --preview='echo {} | jq -C .' | jq .error
tree -CAa
tree -CAa -I .git
tree -CAa -I .git $(fd -t d | fzf --preview="eza --color=always --icons -lAs type {}")
zellij
zellij --debug
zellij --layout compact
zellij --layout default
zellij --layout hint
zellij --layout minimal
zellij -s "$(printf "Enter new session name: " >&2; read i; echo "$i")"
zellij d "$(printf "Enter new session name: " >&2; read i; echo "$i")"
zellij d "$(zellij ls | fzf --height=10 --ansi | cut -d " " -f 1)"
zellij d "$(zellij ls | fzf --height=10 --ansi | cut -d " " -f 1)" --force
zellij d -f Default
zellij da
zellij da -f
zellij k Default
zellij ka
zellij setup --dump-layout=compact > zellij/.config/zellij/layouts/compact.kdl
zellij setup --dump-swap-layout=compact > zellij/.config/zellij/layouts/compact.swap.kdl
zellij_tab_name_update
zle -al | fzf
zoxide edit
